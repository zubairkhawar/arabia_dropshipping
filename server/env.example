# Copy this file to .env and fill in your values.
# Required for the app to start:

# PostgreSQL connection string
# Local: postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME
# Cloud (e.g. Supabase/Neon/RDS): use the URL they provide
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/arabia

# Redis (optional; used for caching/sessions if you add that later)
REDIS_URL=redis://localhost:6379/0

# JWT secret for auth tokens (use a long random string)
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# Optional: create first admin user on startup
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-admin-password

# Optional: API keys (can also set via Admin Settings in the app)
# OPENAI_API_KEY=sk-...
# WATI_API_KEY=...

# Optional: environment
# ENVIRONMENT=development
# DEBUG=true
# FRONTEND_BASE_URL=http://localhost:3000
